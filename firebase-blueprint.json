{
  "entities": {
    "Region": {
      "title": "Region",
      "description": "Chilean regions.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "number": { "type": "number" },
        "code": { "type": "string" }
      },
      "required": ["name"]
    },
    "Party": {
      "title": "Political Party",
      "description": "Chilean political parties.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sigla": { "type": "string" },
        "coalition": { "type": "string" },
        "colorHex": { "type": "string" }
      },
      "required": ["name", "sigla"]
    },
    "Legislator": {
      "title": "Legislator",
      "description": "Represents a Senator or Deputy of the Chilean Congress.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Senator", "Deputy"] },
        "title": { "type": "string" },
        "gender": { "type": "string", "enum": ["M", "F"] },
        "party": { "type": "string" },
        "partyId": { "type": "string" },
        "region": { "type": "string" },
        "regionId": { "type": "string" },
        "district": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "imageUrl": { "type": "string", "format": "uri" },
        "efficiencyScore": { "type": "number" },
        "attendanceRate": { "type": "number" },
        "bio": { "type": "string" }
      },
      "required": ["name", "type", "party", "region", "district", "email"]
    },
    "Project": {
      "title": "Legislative Project",
      "description": "A bill or project being discussed in Congress.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "bulletinNumber": { "type": "string" },
        "summary": { "type": "string" },
        "status": { "type": "string" },
        "chamber": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "bulletinNumber"]
    },
    "Vote": {
      "title": "Vote",
      "description": "Individual vote of a legislator on a project.",
      "type": "object",
      "properties": {
        "legislatorId": { "type": "string" },
        "projectId": { "type": "string" },
        "vote": { "type": "string", "enum": ["Yes", "No", "Abstain", "Absent"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["legislatorId", "projectId", "vote"]
    },
    "Message": {
      "title": "Message",
      "description": "Citizens' messages to legislators (Derecho de Petición).",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "legislatorId": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["Sent", "Received", "Answered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "legislatorId", "subject", "body"]
    }
  },
  "firestore": {
    "/regions/{regionId}": { "schema": "Region", "description": "Chilean regions." },
    "/parties/{partyId}": { "schema": "Party", "description": "Political parties." },
    "/legislators/{legislatorId}": { "schema": "Legislator", "description": "Senators and deputies." },
    "/projects/{projectId}": { "schema": "Project", "description": "Legislative bills." },
    "/legislators/{legislatorId}/votes/{voteId}": { "schema": "Vote", "description": "Votes by legislator." },
    "/users/{userId}/messages/{messageId}": { "schema": "Message", "description": "Sent messages." }
  }
}
