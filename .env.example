# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# In Cloud Run this will be automatically set via the Cloud Run service URL.
APP_URL="https://YOUR_PROJECT_ID-run.app.cloud.goog"

# Firebase/Firestore Configuration
# In Cloud Run, these are automatically available via Application Default Credentials (ADC).
# The project ID is detected from the GOOGLE_CLOUD_PROJECT or FIRESTORE_PROJECT_ID env var.
NEXT_PUBLIC_FIREBASE_PROJECT_ID="YOUR_GCP_PROJECT_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
NEXT_PUBLIC_FIREBASE_FIRESTORE_DB_ID="(default)"